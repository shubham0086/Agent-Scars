# Agent-Scars Environment Variables

# Optional: SQLite database path (default: ./data/scars.db)
# SCAR_DB_PATH=./data/scars.db

# Optional: Fallback JSON incidents file (default: ./data/incidents.json)
# SCAR_FALLBACK_PATH=./data/incidents.json

# Optional: Log level (default: 'warn')
# SCAR_LOG_LEVEL=info

# Optional: Enable verbose debugging
# DEBUG=agent-scars:*
